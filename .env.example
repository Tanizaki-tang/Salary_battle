# =========================================================
# LLM (Alibaba Bailian OpenAI-compatible)
# =========================================================
# Required for real HR-Agent LLM decision path.
BAILIAN_API_KEY=your_bailian_api_key_here

# Optional: OpenAI-compatible endpoint/model/timeout
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus
BAILIAN_TIMEOUT_SECONDS=30


# =========================================================
# sherpa-onnx ASR (voice_battle / speech_gateway)
# =========================================================
# Supported values: paraformer | transducer
# Recommended: offline paraformer (NOT streaming zipformer under models/models)
SHERPA_ONNX_MODEL_TYPE=paraformer

# Option A (recommended): give model dir, code auto-resolves model files.
# Download: https://github.com/k2-fsa/sherpa-onnx/releases/download/asr-models/sherpa-onnx-paraformer-zh-2023-09-14.tar.bz2
SHERPA_ONNX_MODEL_DIR=D:\School\HackSong\Salary_battle\models\sherpa-onnx-paraformer-zh-2023-09-14

# Option B (explicit file paths), used when MODEL_DIR is empty.
SHERPA_ONNX_TOKENS=
SHERPA_ONNX_PARAFORMER=

# Runtime tuning
SHERPA_ONNX_PROVIDER=cpu
SHERPA_ONNX_NUM_THREADS=1
SHERPA_ONNX_DECODING_METHOD=greedy_search
SHERPA_ONNX_MAX_ACTIVE_PATHS=4
SHERPA_ONNX_DEFAULT_CONFIDENCE=0.9

# FFmpeg for browser webm -> wav conversion (optional if ffmpeg is on PATH)
FFMPEG_PATH=


# =========================================================
# App runtime (optional)
# =========================================================
API_HOST=127.0.0.1
API_PORT=8000
# 隐式全局回合上限（可选）：为空表示仅使用场景 max_round；设置后实际上限= min(场景max_round, 本值)
GAME_IMPLICIT_MAX_ROUND=
# 实时连线开关（WebSocket）
REALTIME_WS_ENABLED=true
# WS 心跳秒数（预留）
WS_HEARTBEAT_SECONDS=20
# Agent 回复流式开关（用于实时打字）
LLM_STREAM_ENABLED=true
# WS实时TTS播报开关（server.hr_audio_chunk）
REALTIME_TTS_ENABLED=true
# browser = 浏览器 SpeechSynthesis；backend = sherpa-onnx VITS
REALTIME_TTS_MODE=browser

# Frontend runtime
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_REALTIME_WS_ENABLED=true
VITE_REALTIME_TTS_ENABLED=true
VITE_WS_BASE_URL=ws://127.0.0.1:8000
# 浏览器 TTS 音色调优（Windows 推荐 Xiaoxiao / Yunxi Natural）
VITE_TTS_VOICE_NAME=
VITE_TTS_RATE=0.92
VITE_TTS_PITCH=1.02
VITE_TTS_VOLUME=1
