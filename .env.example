# =========================================================
# LLM (Alibaba Bailian OpenAI-compatible)
# =========================================================
# Required for real HR-Agent LLM decision path.
BAILIAN_API_KEY=your_bailian_api_key_here

# Optional: OpenAI-compatible endpoint/model/timeout
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus
BAILIAN_TIMEOUT_SECONDS=30
LLM_LATENCY_LOG=false
# 卡牌对话模式：lite（默认，仅 HR 台词走 LLM）| full（全 LLM）| off（全模板）
CARD_GAME_DIALOGUE_MODE=lite

# scene_001 GM 场景文档（默认 backend/scenarios/scene_001_gm.md）
SCENARIO_GM_PATH=

# =========================================================
# App runtime (optional)
# =========================================================
API_HOST=127.0.0.1
API_PORT=8000
# 正式数据库连接串；推荐 PostgreSQL，例如：
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/salary_battle
DATABASE_URL=
# 线上跨域白名单，多个地址用逗号分隔
CORS_ALLOW_ORIGINS=
# 可选：用正则放行一组域名，例如 https://.*\.netlify\.app
CORS_ALLOW_ORIGIN_REGEX=
# 隐式全局回合上限（可选）：为空表示仅使用场景 max_round；设置后实际上限= min(场景max_round, 本值)
GAME_IMPLICIT_MAX_ROUND=

# Frontend runtime
# prod = 正式版（仅选择职位，HR 性格服务端随机）
VITE_APP_VARIANT=prod
VITE_API_BASE_URL=http://127.0.0.1:8000

# =========================================================
# Voice Battle (WebSocket + local ASR + QwenTTS)
# =========================================================
# Qwen-TTS-Realtime uses DashScope API key. If empty, it falls back to BAILIAN_API_KEY.
DASHSCOPE_API_KEY=
QWEN_TTS_MODEL=qwen3-tts-flash-realtime
QWEN_TTS_VOICE=Cherry
QWEN_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_TTS_LANGUAGE_TYPE=Chinese

# sherpa-onnx streaming ASR model directory. It should contain tokens.txt and one of:
# 1) encoder/decoder/joiner (transducer), or 2) encoder/decoder (paraformer).
SHERPA_ONNX_STREAMING_ASR_DIR=
SHERPA_ONNX_ASR_SAMPLE_RATE=16000
SHERPA_ONNX_ASR_NUM_THREADS=2

# 语音 ASR 提供方：cloud（默认，适合 Render/线上）| local（本地 sherpa）
VOICE_BATTLE_ASR_PROVIDER=cloud
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_ASR_LANGUAGE=zh
QWEN_ASR_SAMPLE_RATE=16000
QWEN_ASR_SILENCE_MS=400
QWEN_ASR_VAD_THRESHOLD=0.0
QWEN_ASR_TRANSCRIPTION_MODEL=
