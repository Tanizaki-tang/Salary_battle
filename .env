# =========================
# LLM (Alibaba Bailian OpenAI-compatible)
# =========================
# Required: API key for Bailian
BAILIAN_API_KEY=sk-eb3f9108b644432e9caa8a85a155ac39
# Optional: OpenAI-compatible base URL for Bailian
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# Optional: model name
BAILIAN_MODEL=xop3qwen1b7

# Optional: request timeout in seconds
BAILIAN_TIMEOUT_SECONDS=30

# =========================
# Backend runtime (optional)
# =========================
# API host/port if you want to read from env in future scripts
API_HOST=127.0.0.1
API_PORT=8000


# =========================
# Frontend runtime (optional)
# =========================
# Online mode:
# VITE_API_BASE_URL=https://your-domain.com
# Local dev mode:
VITE_API_BASE_URL=http://127.0.0.1:8000
